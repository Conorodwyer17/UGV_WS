# Phase K: Production Config — Aurora 2.11 Native
# use_bridge=false: Aurora native depth (224x416) + semantic segmentation
# depth_to_registered_pointcloud uses aurora_depth_camera_info (416x224)
# ROS 2 params format: apply to all nodes that load this file (inspection_manager, photo_capture_service).
# Full-system-on-launch: mission auto-starts when Nav2 ready; dry_run false for real motion and photos.

/**:
  ros__parameters:
    # Mission start (full-system-on-launch: auto-start when Nav2 ready)
    start_mission_on_ready: true
    dry_run: false
    nav2_wait_timeout: 90.0

    # Frames (frozen)
    world_frame: slamware_map
    base_frame: base_link
    map_frame: map

    # Topics (frozen)
    detection_topic: /darknet_ros_3d/bounding_boxes
    vehicle_boxes_topic: /aurora_semantic/vehicle_bounding_boxes  # Aurora 2.11 semantic vehicle detection; empty = use YOLO vehicles from detection_topic
    vehicle_detected_topic: /inspection_manager/vehicle_detected
    segmentation_mode_topic: /segmentation_mode
    photo_capture_topic: /inspection_manager/capture_photo
    capture_metadata_topic: /inspection_manager/capture_metadata
    capture_result_topic: /inspection_manager/capture_result
    runtime_diagnostics_topic: /inspection_manager/runtime_diagnostics
    mission_report_topic: /inspection_manager/mission_report

    # Aurora 2.11 native (firmware 2.11+)
    use_bridge: false
    depth_image_topic: /slamware_ros_sdk_server_node/depth_image_raw
    depth_image_resolution: [224, 416]
    semantic_segmentation_topic: /slamware_ros_sdk_server_node/semantic_segmentation
    point_cloud_topic_stereo: /slamware_ros_sdk_server_node/point_cloud
    camera_depth_points_topic: /camera/depth/points

    # Detection (inspection_manager expects comma-separated string)
    vehicle_labels: "car,truck"
    tire_label: car-tire
    min_vehicle_probability: 0.5
    min_tire_probability: 0.35

    # Offsets (meters)
    approach_offset: 0.5
    tire_offset: 0.4
    standoff_distance: 2.0

    # Tolerances
    tire_position_tolerance: 0.5
    max_tire_distance_from_vehicle: 5.0
    vehicle_duplicate_tolerance: 2.0

    # Timeouts (seconds)
    detection_timeout: 5.0
    tf_watchdog_timeout: 0.2
    tf_unavailable_abort_s: 60.0   # after this many seconds of continuous TF failure, transition to ERROR
    tf_wait_timeout: 60.0         # max wait for TF (slamware_map->base_link) in IDLE before starting mission
    tf_stable_s: 5.0              # require TF valid for 5s in IDLE before starting (avoids start-then-pause; Aurora must be streaming)
    hard_mission_timeout: 1800.0
    approach_timeout_s: 120.0     # max seconds in APPROACH_VEHICLE or INSPECT_TIRE before cancel and retry (avoids stuck nav)

    # Retry budgets
    max_rotation_attempts: 8
    max_state_repeats: 3
    nav_retry_budget: 3

    # Tire coverage
    expected_tires_per_vehicle: 4

    # Nav2 goal checker (from nav_aurora.yaml)
    xy_goal_tolerance: 0.25
    yaw_goal_tolerance: 0.25

    # Mission logging (for headless runs; review after reconnect)
    # Paths support ~ and $HOME. startup.sh creates ~/ugv_ws/logs.
    mission_log_path: "~/ugv_ws/logs/mission_latest.jsonl"
    mission_report_path: "~/ugv_ws/logs/mission_report_latest.json"

    # Photo capture (photo_capture_service)
    save_directory: "~/ugv_ws/tire_inspection_photos"
