# Build and installation artifacts
build/
install/
log/
logs/

# Python cache
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
.pytest_cache/

# ROS 2 specific
**/COLCON_IGNORE
**/AMENT_IGNORE

# IDE directories
.vscode/
.idea/
*.swp
*.swo
*~

# Personal/thesis files
thesis/
*.bak
*.orig

# Simulation bags
sim/bags/
*.bag
*.bag.active

# Local configuration (if any)
*.local
*.user

# Model files: keep best_fallback.pt and .engine for production.
# Do not ignore model files.

# Any other temporary or large files
*.log
*.out
*.err
*.db
*.sqlite

# Session captures and local diagnostics (not for version control)
diagnostics/

# Large benchmark captures (workspace-local only; *.log also matches)
benchmarks/*.log

# Generated (from original)
tire_inspection_photos/
runs/

# Large local training exports (cloud GPU logs, plots; not required to build)
tyre_training_results/
vision_test_logs/
indoor_test_logs/
backups/
tmp/

# Binaries and data
*.deb
datasets/

