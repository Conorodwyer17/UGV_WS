  <exec_depend>ugv_nav</exec_depend>
  <exec_depend>segmentation_3d</exec_depend>
  <exec_depend>inspection_manager</exec_depend>
  <exec_depend>aurora_mock</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
